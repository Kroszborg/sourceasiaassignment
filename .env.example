NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional. Use only for admin-only scripts; never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SEED_USER_EMAIL=test.passenger@example.com
SEED_USER_PASSWORD=SourceAsia123!

# Optional aliases some Supabase/Vercel setups provide. The app does not require
# these if NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are set.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
